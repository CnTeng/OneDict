{
  "name": "onedict",
  "version": "0.0.1",
  "description": "Look up words in online dictionaries and add to Anki",
  "author": "CnTeng",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build:chrome": "tsx scripts/build.ts chrome",
    "build:firefox": "tsx scripts/build.ts firefox",
    "build:zotero": "tsx scripts/build.ts zotero",
    "build": "run-p -sl build:*",
    "package:chrome": "tsx scripts/build.ts chrome --package",
    "package:firefox": "tsx scripts/build.ts firefox --package",
    "package:zotero": "tsx scripts/build.ts zotero --package",
    "package": "npm run clean && run-p -sl package:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/chrome": "^0.2.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "@vitest/browser": "^4.1.9",
    "adm-zip": "^0.5.17",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9",
    "zotero-types": "^4.1.2"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "eld": "^2.0.3",
    "lucide": "^1.22.0",
    "sentencex-ts": "^0.1.13-ts",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "prettier": {
    "printWidth": 100,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "tailwindFunctions": [
      "tv",
      "cn",
      "cx"
    ]
  }
}
