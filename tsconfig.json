{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "noEmit": true,
    "strict": true,
    "types": ["chrome", "node", "zotero-types"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@common/*": ["./src/common/*"],
      "@services": ["./src/services/index.ts"],
      "@services/*": ["./src/services/*"],
      "@views": ["./src/views/index.ts"],
      "@views/*": ["./src/views/*"]
    }
  },
  "include": [
    "build/**/*",
    "src/env.d.ts",
    "src/common/**/*",
    "src/platforms/**/*",
    "src/services/**/*",
    "src/views/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
